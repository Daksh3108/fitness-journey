+(function () {
+  const bar = document.querySelector(".scroll-progress");
+  if (!bar) return;
+
+  const update = () => {
+    const scrollable =
+      document.documentElement.scrollHeight - window.innerHeight;
+    const pct = scrollable > 0 ? (window.scrollY / scrollable) * 100 : 0;
+    bar.style.width = pct + "%";
+  };
